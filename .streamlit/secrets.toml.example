# Template for Streamlit Community Cloud secrets.
#
# Do NOT commit a real secrets.toml to git. On share.streamlit.io, paste
# these into your app's Settings -> Secrets box instead of using this file.
# For local development, use .env instead (this file is only read by
# Streamlit, and .streamlit/secrets.toml is gitignored).
#
# NOTE: Ollama does not work on Streamlit Community Cloud (their servers
# don't have it installed) — deployed apps must use LLM_PROVIDER = "openrouter".

LLM_PROVIDER = "openrouter"
OPENROUTER_API_KEY = "sk-or-v1-your-key-here"
# OPENROUTER_MODEL = "openai/gpt-oss-20b"
APP_PASSWORD = "choose-a-shared-password"
